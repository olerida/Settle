---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { copy, defaultLanguage, isLanguage, languages } from '../../data/i18n';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = isLanguage(Astro.params.lang) ? Astro.params.lang : defaultLanguage;
const t = copy[lang];
const downloadUrl = 'https://github.com/olerida/Settle/releases/latest/download/Settle.dmg';
const githubUrl = 'https://github.com/olerida/Settle';
---

<BaseLayout lang={lang} title={t.metaTitle} description={t.metaDescription}>
  <header class="site-header" aria-label="Settle">
    <a class="brand" href={`/${lang}`} aria-label="Settle">
      <img src="/app-icon.png" width="32" height="32" alt="" />
      <span>Settle</span>
    </a>
    <nav class="nav-links">
      <a class="nav-features" href="#features">{t.navFeatures}</a>
      <a href="#demo">{t.navDemo}</a>
      <a class="nav-privacy" href="#privacy">{t.navPrivacy}</a>
      <a href="#install">{t.navInstall}</a>
      <a class="download-link" href="#download">{t.navDownload}</a>
    </nav>
  </header>

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="eyebrow">{t.heroEyebrow}</p>
        <h1 id="hero-title">Settle</h1>
        <p class="hero-title">{t.heroTitle}</p>
        <p class="hero-body">{t.heroBody}</p>
        <div class="hero-actions">
          <a class="primary-button" href={downloadUrl}>{t.primaryCta}</a>
          <a class="secondary-button" href={githubUrl}>{t.secondaryCta}</a>
        </div>
        <p class="download-meta">{t.downloadMeta}</p>
      </div>

      <div class="product-visual" aria-label={t.visualSubtitle}>
        <picture class="real-app-shot">
          <source srcset="/settle-menu-dark.png" media="(prefers-color-scheme: dark)" />
          <img src="/settle-menu-light.png" width="960" height="960" alt={t.screenshotAlt} loading="eager" decoding="async" />
        </picture>
      </div>
    </section>

    <section class="requirements-strip" aria-label={t.requirementsTitle}>
      <div>
        <span>{t.requirementsTitle}</span>
        <strong>{t.requirementMinimum}</strong>
      </div>
      <div>
        <span>{t.requirementChip}</span>
        <strong>{t.requirementSize}</strong>
      </div>
      <div>
        <span>{t.requirementSignature}</span>
        <strong>{t.trustLine}</strong>
      </div>
    </section>

    <section id="demo" class="demo-section" aria-labelledby="demo-title">
      <div class="demo-copy">
        <p class="eyebrow">Settle</p>
        <h2 id="demo-title">{t.demoTitle}</h2>
        <p>{t.demoBody}</p>
      </div>
      <video class="demo-video" controls playsinline preload="metadata" poster="/demo-poster.jpg" aria-label={t.demoVideoLabel}>
        <source src="/Demo Settle.mov" type="video/quicktime" />
      </video>
    </section>

    <section id="features" class="support-section">
      <div class="section-lead">
        <p class="eyebrow">{t.navFeatures}</p>
        <h2>{t.supportTitle}</h2>
        <p>{t.supportBody}</p>
      </div>
      <div class="feature-list">
        <article>
          <span>01</span>
          <h3>{t.supportOneTitle}</h3>
          <p>{t.supportOneBody}</p>
        </article>
        <article>
          <span>02</span>
          <h3>{t.supportTwoTitle}</h3>
          <p>{t.supportTwoBody}</p>
        </article>
        <article>
          <span>03</span>
          <h3>{t.supportThreeTitle}</h3>
          <p>{t.supportThreeBody}</p>
        </article>
      </div>
    </section>

    <section class="mid-cta">
      <h2>{t.midCtaTitle}</h2>
      <a class="primary-button" href={downloadUrl}>{t.primaryCta}</a>
    </section>

    <section class="workflow-section">
      <div>
        <h2>{t.workflowTitle}</h2>
        <p>{t.workflowBody}</p>
      </div>
      <ol class="workflow-steps">
        <li>{t.stepOne}</li>
        <li>{t.stepTwo}</li>
        <li>{t.stepThree}</li>
      </ol>
    </section>

    <section class="detail-section" id="privacy">
      <div class="detail-copy">
        <h2>{t.accessibilityTitle}</h2>
        <p>{t.accessibilityBody}</p>
      </div>
      <ul class="detail-list">
        <li>{t.accessibilityDoes}</li>
        <li>{t.accessibilityDoesNot}</li>
        <li>{t.detailThree}</li>
      </ul>
    </section>

    <section class="source-section">
      <div>
        <h2>{t.sourceTitle}</h2>
        <p>{t.sourceBody}</p>
      </div>
      <a class="secondary-button" href={githubUrl}>{t.secondaryCta}</a>
    </section>

    <section class="privacy-section">
      <h2>{t.detailTitle}</h2>
      <p>{t.detailBody}</p>
      <ul class="detail-list compact-list">
        <li>{t.detailOne}</li>
        <li>{t.detailTwo}</li>
        <li>{t.privacyBody}</li>
      </ul>
    </section>

    <section id="install" class="install-section" aria-labelledby="install-title">
      <div class="install-copy">
        <p class="eyebrow">macOS</p>
        <h2 id="install-title">{t.installTitle}</h2>
        <p>{t.installBody}</p>
        <small>{t.installNote}</small>
      </div>
      <div class="install-methods">
        <div>
          <span>{t.directInstallLabel}</span>
          <a href={downloadUrl}>{t.primaryCta}</a>
        </div>
        <div>
          <span>{t.homebrewInstallLabel}</span>
          <code>brew install --cask olerida/tap/settle</code>
        </div>
      </div>
      <video class="install-video" controls playsinline preload="metadata" poster="/settle-preview.png" aria-label={t.installVideoLabel}>
        <source src="/install.mp4" type="video/mp4" />
      </video>
    </section>

    <section id="download" class="final-cta">
      <h2>{t.finalTitle}</h2>
      <p>{t.finalBody}</p>
      <a class="primary-button" href={downloadUrl}>{t.primaryCta}</a>
    </section>
  </main>

  <footer class="site-footer">
    <span>{t.footer}</span>
    <div class="language-links" aria-label={t.languageLabel}>
      {languages.map((locale) => (
        <a href={`/${locale}`} aria-current={locale === lang ? 'page' : undefined}>{locale.toUpperCase()}</a>
      ))}
    </div>
  </footer>
</BaseLayout>
