---
const supportedLanguages = ['en', 'es', 'ca', 'fr', 'de'];
const fallbackLanguage = 'en';
const canonical = new URL('/', Astro.site);
const socialImage = new URL('/settle-preview.png', Astro.site);
---

<!doctype html>
<html lang={fallbackLanguage}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Settle - Your Mac windows, right where you left them</title>
    <meta name="description" content="Switch between work, coding, meeting, and study setups in seconds. Settle restores every window while leaving unrelated windows untouched." />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Settle" />
    <meta property="og:title" content="Settle - Your Mac windows, right where you left them" />
    <meta property="og:description" content="Switch between work, coding, meeting, and study setups in seconds. Settle restores every window while leaving unrelated windows untouched." />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Settle window layout manager for macOS" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Settle - Your Mac windows, right where you left them" />
    <meta name="twitter:description" content="Switch between work, coding, meeting, and study setups in seconds. Settle restores every window while leaving unrelated windows untouched." />
    <meta name="twitter:image" content={socialImage} />
    <link rel="canonical" href={canonical} />
    <script is:inline define:vars={{ supportedLanguages, fallbackLanguage }}>
      const browserLanguages = navigator.languages?.length ? navigator.languages : [navigator.language];
      const normalizedLanguages = browserLanguages
        .map((value) => value?.toLowerCase())
        .filter(Boolean);
      const prefersSpanish = normalizedLanguages.some((value) => value === 'es' || value.startsWith('es-'));
      const language = prefersSpanish
        ? 'es'
        : normalizedLanguages
          .map((value) => value.split('-')[0])
          .find((value) => supportedLanguages.includes(value)) || fallbackLanguage;

      window.location.replace(`/${language}`);
    </script>
  </head>
  <body>
    <noscript>
      <meta http-equiv="refresh" content={`0;url=/${fallbackLanguage}`} />
      <a href={`/${fallbackLanguage}`}>Settle</a>
    </noscript>
  </body>
</html>
