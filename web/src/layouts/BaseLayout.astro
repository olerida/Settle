---
import '../styles/global.css';
import { languages, type Language } from '../data/i18n';

type Props = {
  lang: Language;
  title: string;
  description: string;
};

const { lang, title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL('/settle-preview.png', Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Settle" />
    <meta property="og:title" content="Settle - Window layouts for macOS" />
    <meta property="og:description" content="Save and restore your Mac window layouts in one click." />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Settle window layout manager for macOS" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Settle - Window layouts for macOS" />
    <meta name="twitter:description" content="Save and restore your Mac window layouts in one click." />
    <meta name="twitter:image" content={socialImage} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/app-icon.png" />
    {languages.map((locale) => (
      <link rel="alternate" hreflang={locale} href={`/${locale}`} />
    ))}
  </head>
  <body>
    <slot />
  </body>
</html>
